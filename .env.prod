# Used by `npm run build:prod` (--mode prod).
# Leave EMPTY so axios uses relative `/api/*` paths and Vercel's rewrite
# in vercel.json proxies to the EC2 backend. Setting a value here
# bypasses the rewrite and will break the deployed app if the value
# is wrong (you'll see "Unexpected token '<'" because a parked/HTML
# page gets returned instead of JSON).
VITE_API_BASE_URL=
